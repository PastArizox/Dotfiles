{
    "position": "top",
    "spacing": 5,
    "name": "waybar",
    "margin-bottom": 5,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left": [
        "sway/workspaces",
        "sway/scratchpad",
        "sway/mode"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "memory",
        "cpu",
        "pulseaudio",
        "network",
        "bluetooth",
        "battery"
    ],
    "sway/workspaces": {
        "disable-scroll": true,
        "format": "{index}: {icon}",
        "format-icons": {
            "1": "’äĀ",
            "2": "’äĪ",
            "3": "’ÄÆ",
            "4": "’å╝",
            "5": "’ćś"
        },
        "persistent_workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": [
            "",
            "’ŗÆ"
        ],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "clock": {
        "format": "{:%H:%M - %Y-%m-%d}",
        "format-alt": "{:%H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
        "interval": 1,
        "format": "’ŗø {usage}%"
    },
    "memory": {
        "interval": 1,
        "format": "’öĖ {percentage}%",
        "format-alt": "’öĖ {used}/{total} GiB",
        "tooltip-format": "{used}/{total} GiB used"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}% (’Ŗö)",
        "format-muted": "’Ć”",
        "format-icons": {
            "headphones": "’Ćź",
            "handsfree": "’¢É",
            "headset": "’¢É",
            "phone": "’éĢ",
            "portable": "’éĢ",
            "car": "’å╣",
            "default": [
                "’Ć¦",
                "’Ć©"
            ]
        },
        "scroll-step": 1,
        "on-click": "pavucontrol"
    },
    "network": {
        "format": "{ifname}",
        "format-wifi": "’ć½ ({signalStrength}%)",
        "format-ethernet": "’āü {ifname}",
        "format-disconnected": "’ü▓ DISCONNECTED",
        "format-disabled": "’ü▓ DISABLED",
        "tooltip-format": "{ifname}",
        "tooltip-format-wifi": "’ć½ {essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "’āü {ifname}",
        "tooltip-format-disconnected": "Disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "max-length": 50
    },
    "bluetooth": {
        "on-click": "foot -e bluetoothctl"
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "’ā¦ {icon} {capacity}%",
        "format-discharging": "{icon} {capacity}%",
        "format-plugged": "’ć” {icon} {capacity}%",
        "format-icons": [
            "’ēä",
            "’ēā",
            "’ēé",
            "’ēü",
            "’ēĆ"
        ]
    }
}