{
    "position": "top",
    "spacing": 5,
    "name": "waybar",
    "margin-bottom": 5,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left": [
        "sway/workspaces",
        "sway/scratchpad",
        "sway/mode"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "memory",
        "cpu",
        "pulseaudio",
        "network",
        "bluetooth",
        "battery"
    ],
    "sway/workspaces": {
        "disable-scroll": true,
        "format": "{index}: {icon}",
        "format-icons": {
            "1": "´äá",
            "2": "´äí",
            "3": "´ÄÆ",
            "4": "´å╝",
            "5": "´çÿ"
        },
        "persistent_workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": [
            "",
            "´ïÆ"
        ],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "clock": {
        "format": "{:%H:%M - %Y-%m-%d}",
        "format-alt": "{:%H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
        "interval": 1,
        "format": "´ïø {usage}%"
    },
    "memory": {
        "interval": 1,
        "format": "´ö© {percentage}%",
        "format-alt": "´ö© {used}/{total} GiB",
        "tooltip-format": "{used}/{total} GiB used"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}% (´èö)",
        "format-muted": "´Çª",
        "format-icons": {
            "headphones": "´ÇÑ",
            "handsfree": "´ûÉ",
            "headset": "´ûÉ",
            "phone": "´éò",
            "portable": "´éò",
            "car": "´å╣",
            "default": [
                "´Çº",
                "´Ç¿"
            ]
        },
        "scroll-step": 1,
        "on-click": "pavucontrol"
    },
    "network": {
        "format": "{ifname}",
        "format-wifi": "´ç½ ({signalStrength}%)",
        "format-ethernet": "´âü {ifname}",
        "format-disconnected": "´ü▓ DECO",
        "format-disabled": "´ü▓ DBLD",
        "tooltip-format": "{ifname}",
        "tooltip-format-wifi": "´ç½ {essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "´âü {ifname}",
        "tooltip-format-disconnected": "Disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "max-length": 50
    },
    "bluetooth": {
        "on-click": "foot -e bluetoothctl"
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "´âº {icon} {capacity}%",
        "format-discharging": "{icon} {capacity}%",
        "format-plugged": "´çª {icon} {capacity}%",
        "format-icons": [
            "´ëä",
            "´ëâ",
            "´ëé",
            "´ëü",
            "´ëÇ"
