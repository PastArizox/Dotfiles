{
    "position": "top",
    "spacing": 5,
    "name": "waybar",
    "margin-bottom": 5,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left": [
        "sway/workspaces",
        "sway/scratchpad",
        "sway/mode"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "memory",
        "cpu",
        "pulseaudio",
        "network",
        "bluetooth",
        "battery"
    ],
    "sway/workspaces": {
        "disable-scroll": true,
        "format": "{index}: {icon}",
        "format-icons": {
            "1": "яДа",
            "2": "яДб",
            "3": "яОТ",
            "4": "яЖ╝",
            "5": "яЗШ",
            "6": "яАЩ",
            "10": "юД▒"
        },
        "persistent_workspaces": {
            "1": [
                "eDP-1"
            ],
            "2": [
                "eDP-1"
            ],
            "3": [
                "eDP-1"
            ],
            "4": [
                "eDP-1"
            ],
            "5": [
                "eDP-1"
            ],
            "6": [
                "eDP-1"
            ],
            "10": [
                "HDMI-A-1"
            ]
        }
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": [
            "",
            "яЛТ"
        ],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "clock": {
        "format": "{:%H:%M - %Y-%m-%d}",
        "format-alt": "{:%H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
        "interval": 1,
        "format": "яЛЫ {usage}%"
    },
    "memory": {
        "interval": 1,
        "format": "яФ╕ {percentage}%",
        "format-alt": "яФ╕ {used}/{total} GiB",
        "tooltip-format": "{used}/{total} GiB used"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}% (яКФ)",
        "format-muted": "яАж",
        "format-icons": {
            "headphones": "яАе",
            "handsfree": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": [
                "яАз",
                "яАи"
            ]
        },
        "scroll-step": 1,
        "on-click": "pavucontrol"
    },
    "network": {
        "format": "{ifname}",
        "format-wifi": "яЗл ({signalStrength}%)",
        "format-ethernet": "яГБ {ifname}",
        "format-disconnected": "яБ▓ DECO",
        "format-disabled": "яБ▓ DBLD",
        "tooltip-format": "{ifname}",
        "tooltip-format-wifi": "яЗл {essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "яГБ {ifname}",
        "tooltip-format-disconnected": "Disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "max-length": 50
    },
    "bluetooth": {
        "on-click": "foot -e bluetoothctl"
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "яГз {icon} {capacity}%",
        "format-discharging": "{icon} {capacity}%",
        "format-plugged": "яЗж {icon} {capacity}%",
        "format-icons": [
            "яЙД",
            "яЙГ",
            "яЙВ",
            "яЙБ",
            "яЙА"
        ]
    }
}